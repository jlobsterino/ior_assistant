"""
Удобный запуск: `python run.py`.
"""
import uvicorn

from backend.config import get_settings

if __name__ == "__main__":
    cfg = get_settings()
    uvicorn.run(
        "backend.main:app",
        host=cfg.app_host,
        port=cfg.app_port,
        reload=True,
        log_level=cfg.app_log_level.lower(),
    )